# Database Connection Configuration

# MySQL Connection Settings
# Copy this file to .env and update values as needed

# Database Host (usually localhost for local development)
DB_HOST=localhost

# Database User (default root for MySQL)
DB_USER=root

# Database Password (set during MySQL installation)
DB_PASSWORD=root

# Database Name (the database that will be created)
DB_NAME=dbms_warehouse

# Node Environment
NODE_ENV=development

# Server Port
PORT=3000
